{
  "buildCommand": "npm install && echo '跳过 TypeScript 类型检查'",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/tts"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ],
  "functions": {
    "api/tts.js": {
      "maxDuration": 30
    }
  }
}